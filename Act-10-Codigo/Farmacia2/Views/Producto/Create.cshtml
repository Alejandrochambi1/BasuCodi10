@model Farmacia2.Models.Producto

@{
    ViewData["Title"] = "Registrar Nuevo Producto";
}

<h2>📦 Registrar Nuevo Producto</h2>

@{
    ViewData["Title"] = "Registrar Nuevo Producto";
}

<h2>📦 Registrar Nuevo Producto</h2>

<hr />

@if (TempData["Mensaje"] != null)
{
    <div class="alert alert-success">
        @TempData["Mensaje"]
    </div>
}

@if (ViewBag.Error != null)
{
    <div class="alert alert-danger">
        @ViewBag.Error
    </div>
}

<form asp-action="Create" method="post">
    <div class="row">
        <div class="col-md-6">

            <div class="form-group">
                <label>Nombre del Producto</label>
                <input asp-for="Nombre" class="form-control" required />
            </div>

            <div class="form-group">
                <label>Precio (Bs)</label>
                <input asp-for="Precio" type="number" step="0.01" class="form-control" required />
            </div>

            <div class="form-group">
                <label>Stock</label>
                <input asp-for="Stock" type="number" class="form-control" required />
            </div>

            <div class="form-group">
                <label>Fecha de Vencimiento</label>
                <input asp-for="Vencimiento" type="date" class="form-control" />
            </div>

            <div class="form-group">
                <label>ID Proveedor</label>
                <input asp-for="IdProveedor" type="number" class="form-control" required />
            </div>

            <br />
            <button type="submit" class="btn btn-primary">Guardar Producto</button>
            <a asp-action="Create" class="btn btn-secondary">Limpiar</a>
        </div>
    </div>
</form>